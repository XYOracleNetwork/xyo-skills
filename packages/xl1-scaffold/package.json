{
  "name": "@xyo-network/xl1-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "scaffold-xl1": "./dist/scaffold-xl1-dapp.js"
  },
  "scripts": {
    "build": "pnpm clean && tsc && node scripts/copy-templates.mjs && node scripts/sync-to-plugin.mjs",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "scaffold": "node dist/scaffold-xl1-dapp.js",
    "scaffold:dev": "tsx src/scaffold-xl1-dapp.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@xylabs/eslint-config-flat": "~7.12.0",
    "@xylabs/tsconfig": "~7.12.0",
    "eslint": "^10.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}