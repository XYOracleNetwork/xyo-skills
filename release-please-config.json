{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "last-release-sha": "4696901",
  "packages": {
    ".": {
      "package-name": "xyo-skills",
      "changelog-path": "CHANGELOG.md",
      "versioning": "always-bump-patch",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.metadata.version"
        },
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='xyo-skills')].version"
        },
        "skills/xy-development/SKILL.md",
        "skills/xy-toolchain/SKILL.md",
        "skills/xyo-knowledge/SKILL.md",
        "skills/xl1-knowledge/SKILL.md",
        "skills/xl1-patterns/SKILL.md",
        "skills/xl1-build/SKILL.md",
        "skills/xl1-scaffold/SKILL.md"
      ]
    }
  }
}
